#!/bin/bash
# Verifica se o Ionic CLI está instalado.

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # Sem Cor

# Função principal que pode ser chamada por outros scripts.
check_ionic_cli() {
    if ! command -v ionic &> /dev/null; then
        echo -e "${YELLOW}⚠️  Ionic CLI não encontrado. Instalando...${NC}"
        if npm install -g @ionic/cli; then
            echo -e "${GREEN}✅ Ionic CLI instalado com sucesso!${NC}"
            local ionic_version
            ionic_version=$(ionic --version 2>/dev/null || echo "desconhecida")
            echo -e "${CYAN}📋 Versão instalada: $ionic_version${NC}"
        else
            echo -e "${RED}❌ Falha na instalação do Ionic CLI${NC}"
            echo -e "${YELLOW}💡 Tente instalar manualmente:${NC}"
            echo -e "   npm install -g @ionic/cli"
            exit 1
        fi
    fi
    # Removido echo de sucesso para evitar duplicação
}

# Permite que o script seja executado diretamente para teste.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    check_ionic_cli
fi