#!/bin/bash

# Script principal do SITFOR App - Ubuntu/Linux
set -e

# Cores para o terminal
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_error()   { echo -e "${RED}[ERRO]${NC} $1"; }

# Verifica dependências essenciais
check_dependencies() {
    for cmd in node npm; do
        if ! command -v $cmd &>/dev/null; then
            log_error "Dependência '$cmd' não encontrada. Instale antes de continuar."; exit 1;
        fi
    done
}

# Verifica se o Capacitor CLI está instalado
check_capacitor_cli() {
    if ! npx --no-install cap --version &>/dev/null; then
        log_info "@capacitor/cli não encontrado. Instalando..."
        npm install --save-dev @capacitor/cli || { log_error "Falha ao instalar @capacitor/cli."; exit 1; }
    fi
}

# Garante execução na raiz do projeto
ensure_project_root() {
    if [ ! -f "package.json" ] || [ ! -f "capacitor.config.ts" ]; then
        log_error "Execute este script na raiz do projeto SITFOR."; exit 1;
    fi
}

# Garante que a pasta www existe e tem index.html
ensure_www_exists() {
    if [ ! -d "www" ] || [ ! -f "www/index.html" ]; then
        log_info "Gerando arquivos web (npm run build)..."
        npm run build || { log_error "Falha ao gerar arquivos web."; exit 1; }
    fi
}


# Verifica se o 'dialog' está instalado
ensure_dialog_installed() {
    if ! command -v dialog &>/dev/null; then
        log_info "O utilitário 'dialog' não está instalado. Instalando..."
        if command -v apt-get &>/dev/null; then
            if ! sudo apt-get update || ! sudo apt-get install -y dialog; then
                log_error "Falha ao instalar 'dialog'. Instale manualmente."; exit 1;
            fi
        else
            log_error "Gerenciador de pacotes não suportado. Instale 'dialog' manualmente."; exit 1;
        fi
    fi
}

# Menu principal usando dialog
main_menu() {
    local choice
    while true; do
        choice=$(dialog --clear --stdout \
            --title "SITFOR App - Menu Principal" \
            --menu "Selecione uma opção:" 13 60 6 \
            "Desenvolvimento - Servidor local" "" \
            "Build Android - Compilar APK" "" \
            "Build Web - Apenas arquivos web" "" \
            "Limpar projeto" "" \
            "Instalar dependências" "" \
            "Sair" "")

        case $choice in
            "Desenvolvimento - Servidor local")
                log_info "Iniciando servidor de desenvolvimento..."
                ./bin/dev || log_error "Erro ao iniciar servidor de desenvolvimento."
                ;;
            "Build Android - Compilar APK")
                log_info "Preparando build Android..."
                ensure_www_exists
                check_capacitor_cli
                if [ -d "android" ]; then
                    log_info "Removendo plataforma Android antiga..."
                    rm -rf android || { log_error "Erro ao remover pasta android."; exit 1; }
                fi
                log_info "Adicionando plataforma Android..."
                npx cap add android || { log_error "Erro ao adicionar plataforma Android."; exit 1; }
                npx cap sync android || { log_error "Erro ao sincronizar Capacitor Android."; exit 1; }
                log_info "Compilando APK (assembleDebug)..."
                cd android && ./gradlew assembleDebug || { log_error "Erro ao compilar APK."; exit 1; }
                cd ..
                log_info "Instalando e abrindo app no dispositivo (se conectado)..."
                npx cap run android || log_info "Abra manualmente no Android Studio se necessário."
                ;;
            "Build Web - Apenas arquivos web")
                log_info "Iniciando build web..."
                ./bin/build || log_error "Erro ao executar build web."
                ;;
            "Limpar projeto")
                log_info "Limpando projeto..."
                ./bin/clean || log_error "Erro ao limpar projeto."
                ;;
            "Instalar dependências")
                log_info "Checando e instalando dependências do ambiente..."
                bin/checks/check_android_env.sh
                # O script check_android_env.sh agora controla a saída ou o retorno.
                if [ $? -eq 1 ]; then
                    log_info "Saindo conforme escolha do usuário na checagem de dependências."
                    clear
                    exit 0
                fi
                continue
                ;;
            "Sair")
                log_info "Saindo..."
                clear
                exit 0
                ;;
            *)
                log_error "Opção inválida. Tente novamente."
                ;;
        esac
    done
}

# Execução principal

main() {
    ensure_project_root
    check_dependencies
    ensure_dialog_installed
    main_menu
}

main "$@"
# Script principal do SITFOR App
# Menu interativo para diferentes operações do projeto

set -e

# Cores para o terminal
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Função para ler teclas especiais
read_key() {
    local key
    read -rsn1 key
    
    case $key in
        $'\x1b')  # ESC sequence
            read -rsn2 key
            case $key in
                '[A') echo "up" ;;
                '[B') echo "down" ;;
                '[C') echo "right" ;;
                '[D') echo "left" ;;
                *) echo "escape" ;;
            esac
            ;;
        '') echo "enter" ;;
        ' ') echo "space" ;;
        'q'|'Q') echo "quit" ;;
        *) echo "$key" ;;
    esac
}

# Função para exibir logs coloridos
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Função para mostrar o menu principal com navegação
show_main_menu() {
    local selected=$1
    local options=("Desenvolvimento - Servidor local" "Build Android - Compilar APK" "Build Web - Apenas arquivos web" "Testes - Executar testes" "Limpar projeto" "Instalar dependências" "Sair")
    
    clear
    echo -e "${BOLD}${CYAN}=====================================${NC}"
    echo -e "${BOLD}${CYAN}       SITFOR App - Menu Principal${NC}"
    echo -e "${BOLD}${CYAN}=====================================${NC}"
    echo
    echo "Use as setas ↑/↓ para navegar, → ou Enter para selecionar, ← ou ESC para voltar"
    echo
    
    for i in "${!options[@]}"; do
        if [ "$i" -eq "$selected" ]; then
            echo -e "  ${BOLD}${YELLOW}>${NC} ${GREEN}$((i+1)))${NC} ${BOLD}${options[$i]}${NC}"
        else
            echo -e "    ${GREEN}$((i+1)))${NC} ${options[$i]}"
        fi
    done
    echo
}

# Função para menu interativo com navegação por setas
interactive_menu() {
    local selected=0
    local max_options=6
    
    while true; do
        show_main_menu $selected
        
        key=$(read_key)
        
        case $key in
            "up")
                ((selected--))
                if [ $selected -lt 0 ]; then
                    selected=$max_options
                fi
                ;;
            "down")
                ((selected++))
                if [ $selected -gt $max_options ]; then
                    selected=0
                fi
                ;;
            "right"|"enter")
                return $((selected + 1))
                ;;
            "left"|"escape")
                log_info "Saindo..."
                exit 0
                ;;
            "quit")
                log_info "Saindo..."
                exit 0
                ;;
            [1-7])
                return "$key"
                ;;
        esac
    done
}


# Função para garantir execução na raiz do projeto
ensure_project_root() {
    local dir
    dir=$(pwd)
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/package.json" ] && [ -f "$dir/capacitor.config.ts" ]; then
            cd "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    log_error "Este script deve ser executado na raiz do projeto SITFOR."
    exit 1
}

# Função para verificar dependências essenciais
check_dependencies() {
    for cmd in node npm; do
        if ! command -v $cmd &>/dev/null; then
            log_error "Dependência '$cmd' não encontrada. Instale antes de continuar."
            exit 1
        fi
    done
}

# Função para verificar se o Capacitor CLI está instalado
check_capacitor_cli() {
    if ! npx --no-install cap --version &>/dev/null; then
        log_info "@capacitor/cli não encontrado. Instalando..."
        npm install --save-dev @capacitor/cli || {
            log_error "Falha ao instalar @capacitor/cli."; exit 1;
        }
    fi
}

# Função para garantir que a pasta www existe e tem index.html
ensure_www_exists() {
    if [ ! -d "www" ] || [ ! -f "www/index.html" ]; then
        log_info "Gerando arquivos web (npm run build)..."
        npm run build || { log_error "Falha ao gerar arquivos web."; exit 1; }
    fi
}

main() {
    ensure_project_root
    check_dependencies
    check_capacitor_cli

    while true; do
        choice=$(interactive_menu)

        case $choice in
            1)
                log_info "Iniciando servidor de desenvolvimento..."
                ./bin/dev || log_error "Erro ao iniciar servidor de desenvolvimento."
                ;;
            2)
                log_info "Preparando build Android..."
                ensure_www_exists
                check_capacitor_cli
                npx cap sync android || log_error "Erro ao sincronizar Capacitor Android."
                bin/android debug
                ;;
            3)
                log_info "Iniciando build web..."
                ./bin/build || log_error "Erro ao executar build web."
                ;;
            4)
                log_info "Executando testes..."
                ./bin/test || log_error "Erro ao executar testes."
                ;;
            5)
                log_info "Limpando projeto..."
                ./bin/clean || log_error "Erro ao limpar projeto."
                ;;
            6)
                log_info "Instalando dependências..."
                if npm install; then
                    log_success "Dependências instaladas!"
                else
                    log_error "Erro ao instalar dependências."
                fi
                ;;
            7)
                log_info "Saindo..."
                exit 0
                ;;
            *)
                log_error "Opção inválida. Tente novamente."
                ;;
        esac
    done
}

# Executar função principal
main "$@"
