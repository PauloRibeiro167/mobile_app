# Veja https://help.github.com/articles/ignoring-files para mais informações sobre ignorar arquivos.
#
# Arquivos temporários gerados pelo seu editor de texto ou sistema operacional
# devem pertencer ao ignore global do Git:
# `$XDG_CONFIG_HOME/git/ignore` ou `~/.config/git/ignore`

# Ignorar configuração do Bundler.
api/.bundle

# Ignorar todos os arquivos de ambiente.
/.env*

# Ignorar todos os arquivos de log e temporários.
api/log/*
api/tmp/*
!api/log/.keep
!api/tmp/.keep
.cache/

# Ignorar arquivos pid, mas manter o diretório.
api/tmp/pids/*
!api/tmp/pids/
!api/tmp/pids/.keep

# Ignorar storage (arquivos enviados em desenvolvimento e bancos SQLite).
api/storage/*
!api/storage/.keep
api/tmp/storage/*
!api/tmp/storage/
!api/tmp/storage/.keep

# Ignorar chave mestra para descriptografar credenciais e mais.
api/config/master.key

api/tmp/
api/log/
