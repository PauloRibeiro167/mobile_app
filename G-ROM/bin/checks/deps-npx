#!/bin/bash
# Verifica se o npx (Node Package Execute) está instalado.

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Função principal que pode ser chamada por outros scripts.
check_npx_dependencies() {
    # 1. Verificar se o comando 'npx' existe
    if ! command -v "npx" >/dev/null 2>&1; then
        echo -e "${RED}❌ Comando 'npx' não encontrado.${NC}"
        echo -e "   O npx é instalado automaticamente com versões recentes do npm."
        echo -e "   Verifique sua instalação do Node.js e npm."
        return 1
    fi

    local VERSION
    VERSION=$(npx --version)
    echo -e "${GREEN}✅ npx encontrado: v${VERSION}${NC}"
}

# Permite que o script seja executado diretamente para teste.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    check_npx_dependencies
fi


