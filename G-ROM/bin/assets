#!/bin/bash

# Colors for logging
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging functions
log_info() {
  echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
  echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
  echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
  echo -e "${RED}[ERROR]${NC} $1"
}

# Main script
log_info "Iniciando geração de assets (ícones) do Capacitor..."

if npx @capacitor/assets generate; then
  log_success "Assets do Capacitor gerados com sucesso."
else
  log_error "Falha ao gerar assets do Capacitor."
  exit 1
fi

log_info "Sincronizando com Capacitor para Android..."

if ionic capacitor sync android; then
  log_success "Sincronização com Capacitor concluída."
else
  log_error "Falha na sincronização com Capacitor."
  exit 1
fi

log_info "Assets gerados e sincronizados. Pronto para build do APK."
log_info "Para buildar o APK, execute: bin/build android"