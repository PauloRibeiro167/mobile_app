#!/bin/bash
# Script para instalar e executar o app de desenvolvimento em um dispositivo Android.

# Carrega variáveis de ambiente do arquivo .env.development no diretório pai
if [ -f ../.env.development ]; then
    source ../.env.development
fi

# Define o dispositivo padrão para evitar seleção manual (usa variável de ambiente ou padrão)
export ANDROID_SERIAL=${ANDROID_DEVICE_SERIAL:-0084271076}

# --- Funções de Seleção de Dispositivo ---
function list_devices() {
    >&2 echo "Dispositivos Android conectados:"
    adb devices | grep -v 'List' | grep -v '^$' | awk '{print NR ") " $1}' >&2
}

function select_device() {
    local count=$(adb devices | grep -v 'List' | grep -v '^$' | wc -l)
    if [ "$count" -eq 0 ]; then
        >&2 echo "Nenhum dispositivo encontrado. Conecte um dispositivo ou inicie um emulador."
        exit 1
    elif [ "$count" -eq 1 ]; then
        # Seleciona automaticamente se houver apenas um dispositivo
        local id=$(adb devices | grep -v 'List' | grep -v '^$' | awk '{print $1}')
        >&2 echo "Dispositivo selecionado automaticamente: $id"
        echo $id
        return
    fi

    list_devices
    >&2 echo -n "Escolha o número do dispositivo: "
    read num
    local id=$(adb devices | grep -v 'List' | grep -v '^$' | awk "NR==$num {print \$1}")
    if [ -z "$id" ]; then
        >&2 echo "Opção inválida."
        exit 1
    fi
    echo $id
}

# --- Lógica Principal ---

# 1. Verifica se o servidor de desenvolvimento está rodando
if ! pgrep -f "ng serve"; then
    >&2 echo "Servidor de desenvolvimento não encontrado. Iniciando..."
    # Inicia o servidor em background. As configurações de host/porta
    # já estão no angular.json
    ng serve --configuration=development &
    # Aguarda um pouco para o servidor iniciar
    >&2 echo "Aguardando o servidor de desenvolvimento iniciar (15s)..."
    sleep 15
else
    >&2 echo "Servidor de desenvolvimento já está em execução."
fi

# 2. Sincroniza o projeto Capacitor
>&2 echo "Sincronizando projeto com Capacitor..."
npx cap sync android || { >&2 echo "Falha na sincronização do Capacitor."; exit 1; }

# 3. Seleciona o dispositivo de destino
device_id=$(select_device)
if [ -z "$device_id" ]; then
    exit 1
fi

# 4. Instala o APK de debug usando Gradle
>&2 echo "Instalando o app no dispositivo $device_id..."
# A flag -p aponta para o diretório do projeto android
android/gradlew -p android installDebug || { >&2 echo "Falha ao instalar o app com Gradle."; exit 1; }


# 5. Inicia o app no dispositivo
package_id="br.gov.ce.sitfor.app"
>&2 echo "Iniciando o app ($package_id) no dispositivo..."
adb -s $device_id shell am start -n "$package_id/.MainActivity" || { >&2 echo "Falha ao iniciar o app no dispositivo."; exit 1; }

>&2 echo "App instalado e iniciado com sucesso!"
